[mysqld]
# =============================================================================
# Character set
# =============================================================================
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# =============================================================================
# InnoDB
# innodb_buffer_pool_size: servidor com 8GB RAM total, compartilhado com Nginx,
# Redis, PHP-FPM (1 container por projeto Laravel) e containers Python.
# 1G reservado pro MySQL hoje (2 projetos em produção, ~7GB livres no host
# em uso real). Reavaliar conforme mais projetos/containers forem adicionados —
# acompanhar Innodb_buffer_pool_reads vs Innodb_buffer_pool_read_requests
# (SHOW GLOBAL STATUS) antes de aumentar ainda mais.
# innodb_buffer_pool_instances: só compensa a partir de vários GB de pool;
# em 1G, manter em 1 evita overhead de divisão sem ganho real.
# =============================================================================
innodb_buffer_pool_size      = 1G
innodb_buffer_pool_instances = 1
innodb_file_per_table        = 1
innodb_flush_log_at_trx_commit = 1
innodb_flush_method          = O_DIRECT
innodb_io_capacity           = 1000
innodb_io_capacity_max       = 2000

# =============================================================================
# Conexões
# max_connections: ajuste conforme (workers_php_fpm * num_projetos) + folga
# wait_timeout: 600s cobre jobs e migrations longas do Laravel
# max_allowed_packet: necessário para campos TEXT/BLOB e payloads de queue
# =============================================================================
max_connections     = 100
wait_timeout        = 600
interactive_timeout = 600
max_allowed_packet  = 64M

# =============================================================================
# SQL Mode — compatível com Laravel e seguro para produção
# =============================================================================
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# =============================================================================
# Segurança
# =============================================================================
skip-name-resolve
skip-log-bin

# =============================================================================
# Slow query log — essencial para identificar gargalos em produção
# log_queries_not_using_indexes: detecta N+1 e queries sem índice
# =============================================================================
slow_query_log                = 1
slow_query_log_file           = /var/log/mysql/slow.log
long_query_time               = 1
log_queries_not_using_indexes = 1
log_error                     = /var/log/mysql/error.log

# =============================================================================
# Performance
# table_open_cache: múltiplos projetos Laravel geram muitas tabelas
# tmp_table_size: evita tabelas temporárias em disco em queries complexas
# =============================================================================
table_open_cache    = 1024
thread_cache_size   = 16
tmp_table_size      = 64M
max_heap_table_size = 64M

[mysql]
default-character-set = utf8mb4

[client]
default-character-set = utf8mb4
