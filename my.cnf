[mysqld]
# =============================================================================
# Character set
# =============================================================================
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# =============================================================================
# InnoDB
# innodb_buffer_pool_size: regra geral é 70-80% da RAM disponível para MySQL.
# Num servidor compartilhado com múltiplos projetos, use um valor conservador.
# Exemplos: 256M (2 GB RAM), 512M (4 GB RAM), 1G (8 GB RAM)
# =============================================================================
innodb_buffer_pool_size     = 256M
innodb_file_per_table       = 1
innodb_flush_log_at_trx_commit = 1
innodb_flush_method         = O_DIRECT

# =============================================================================
# Conexões
# Ajuste max_connections conforme o número de projetos e workers PHP-FPM.
# Cada projeto Laravel pode abrir múltiplas conexões simultâneas.
# =============================================================================
max_connections = 100
wait_timeout    = 300
interactive_timeout = 300

# =============================================================================
# SQL Mode — compatível com Laravel e seguro para produção
# =============================================================================
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# =============================================================================
# Segurança
# =============================================================================
skip-name-resolve

# =============================================================================
# Slow query log — essencial para identificar gargalos em produção
# =============================================================================
slow_query_log      = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time     = 2
log_error           = /var/log/mysql/error.log

# =============================================================================
# Performance
# =============================================================================
table_open_cache    = 256
thread_cache_size   = 8
query_cache_type    = 0

[mysql]
default-character-set = utf8mb4

[client]
default-character-set = utf8mb4
